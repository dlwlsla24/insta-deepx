# Naver 검색 API (https://developers.naver.com/apps)
# 애플리케이션 등록 → "검색" API 추가 → Client ID / Secret 발급
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
# https://developers.naver.com 접속 → 네이버 계정 로그인
# 상단 Application → 애플리케이션 등록
# 이름 입력(예: insta-deepx), 사용 API = "검색" 체크
# 환경 추가에서 WEB 설정 선택 → 서비스 URL에 아무 값(http://localhost)이라도 입력. 검색 API는 서버에서 호출하는 비로그인 오픈API라 이 URL은 중요하지 않습니다
# 등록하면 발급된 Client ID / Client Secret → .env의 NAVER_CLIENT_ID[커스텀], NAVER_CLIENT_SECRET[커스텀]


# Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_key_here
# https://aistudio.google.com/apikey → 구글 로그인
# Create API key → 프로젝트 선택(없으면 자동 생성)
# 생성된 키 복사 → GEMINI_API_KEY[커스텀]

# Cloudinary (https://cloudinary.com/users/register/free)
# 인스타가 공개 URL을 요구해 중간 호스팅용으로 사용. 무료 티어로 충분.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# https://cloudinary.com/users/register/free 가입 후 로그인
# Dashboard 상단 Product Environment 카드 (또는 Settings → API Keys)
# 여기서 Cloud name / API Key / API Secret(Secret은 눈 아이콘 클릭해 표시) 복사
# 각각 CLOUDINARY_CLOUD_NAME[커스텀], CLOUDINARY_API_KEY[커스텀], CLOUDINARY_API_SECRET[커스텀]

# Instagram API with Instagram Login (https://developers.facebook.com/)
# 딥엑스 전용 인스타 프로페셔널(비즈니스/크리에이터) 계정 필요. Facebook 페이지는 불필요.
#  - INSTAGRAM_ACCESS_TOKEN: 앱 대시보드 Instagram > API setup with Instagram business login
#    의 'Generate token' 버튼으로 받는 60일 토큰
#  - INSTAGRAM_BUSINESS_ID: 아래로 확인
#    curl "https://graph.instagram.com/v23.0/me?fields=user_id,username&access_token=<토큰>"
INSTAGRAM_ACCESS_TOKEN=your_instagram_user_token
INSTAGRAM_BUSINESS_ID=your_ig_user_id
